{
    "openapi": "3.0.0",
    "info": {
        "title": "农产品交易平台 API",
        "version": "1.0.0",
        "description": "农产品交易平台后端接口文档"
    },
    "servers": [
        {
            "url": "http://localhost:8000",
            "description": "本地开发环境"
        }
    ],
    "tags": [
        {
            "name": "认证模块",
            "description": "用户认证相关接口"
        },
        {
            "name": "分类模块",
            "description": "商品分类相关接口"
        },
        {
            "name": "商品模块",
            "description": "商品相关接口"
        },
        {
            "name": "店铺模块",
            "description": "店铺相关接口"
        },
        {
            "name": "购物车模块",
            "description": "购物车相关接口"
        }
    ],
    "paths": {
        "/api/auth/send-code": {
            "post": {
                "tags": [
                    "认证模块"
                ],
                "summary": "发送验证码",
                "description": "发送短信验证码到指定手机号",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "phone"
                                ],
                                "properties": {
                                    "phone": {
                                        "type": "string",
                                        "description": "手机号",
                                        "example": "13800138000"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "成功",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Response"
                                },
                                "example": {
                                    "code": 200,
                                    "message": "验证码发送成功",
                                    "data": {
                                        "message": "验证码已发送",
                                        "code": "123456"
                                    },
                                    "timestamp": 1234567890
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/auth/register": {
            "post": {
                "tags": [
                    "认证模块"
                ],
                "summary": "用户注册",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "username",
                                    "password",
                                    "confirm_password",
                                    "phone",
                                    "code"
                                ],
                                "properties": {
                                    "username": {
                                        "type": "string",
                                        "description": "用户名",
                                        "example": "testuser001"
                                    },
                                    "password": {
                                        "type": "string",
                                        "description": "密码",
                                        "example": "123456"
                                    },
                                    "confirm_password": {
                                        "type": "string",
                                        "description": "确认密码",
                                        "example": "123456"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "description": "手机号",
                                        "example": "13800138000"
                                    },
                                    "code": {
                                        "type": "string",
                                        "description": "验证码",
                                        "example": "123456"
                                    },
                                    "role": {
                                        "type": "string",
                                        "enum": [
                                            "consumer",
                                            "merchant"
                                        ],
                                        "description": "角色",
                                        "example": "consumer"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "成功",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Response"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/auth/login": {
            "post": {
                "tags": [
                    "认证模块"
                ],
                "summary": "用户登录",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "username",
                                    "password"
                                ],
                                "properties": {
                                    "username": {
                                        "type": "string",
                                        "description": "用户名或手机号",
                                        "example": "testuser001"
                                    },
                                    "password": {
                                        "type": "string",
                                        "description": "密码",
                                        "example": "123456"
                                    },
                                    "remember": {
                                        "type": "boolean",
                                        "description": "是否记住密码",
                                        "example": false
                                    },
                                    "role": {
                                        "type": "string",
                                        "enum": [
                                            "consumer",
                                            "merchant"
                                        ],
                                        "description": "期望的角色（用于角色隔离）",
                                        "example": "consumer"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "成功",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Response"
                                },
                                "example": {
                                    "code": 200,
                                    "message": "登录成功",
                                    "data": {
                                        "token": "eyJ0eXAiOiJKV1QiLCJhbGc...",
                                        "user": {
                                            "id": 1,
                                            "username": "testuser001",
                                            "phone": "13800138000",
                                            "avatar": "https://...",
                                            "nickname": null,
                                            "address": "未填写",
                                            "bio": "这位用户很懒，还没有填写简介",
                                            "role": "consumer"
                                        }
                                    },
                                    "timestamp": 1234567890
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/auth/user-info": {
            "get": {
                "tags": [
                    "认证模块"
                ],
                "summary": "获取用户信息",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "成功",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Response"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/auth/reset-password": {
            "post": {
                "tags": [
                    "认证模块"
                ],
                "summary": "重置密码",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "phone",
                                    "code",
                                    "password",
                                    "confirm_password"
                                ],
                                "properties": {
                                    "phone": {
                                        "type": "string",
                                        "description": "手机号",
                                        "example": "13800138000"
                                    },
                                    "code": {
                                        "type": "string",
                                        "description": "验证码",
                                        "example": "123456"
                                    },
                                    "password": {
                                        "type": "string",
                                        "description": "新密码",
                                        "example": "newpass123"
                                    },
                                    "confirm_password": {
                                        "type": "string",
                                        "description": "确认新密码",
                                        "example": "newpass123"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "成功",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Response"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/auth/logout": {
            "post": {
                "tags": [
                    "认证模块"
                ],
                "summary": "退出登录",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "成功",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Response"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/category/list": {
            "get": {
