        "/api/cart/add": {
            "post": {
                "tags": [
                    "购物车模块"
                ],
                "summary": "添加到购物车",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
