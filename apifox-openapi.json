                                    "quantity"
                                ],
                                "properties": {
                                    "product_id": {
                                        "type": "integer",
                                        "description": "商品ID"
                                    },
                                    "spec_id": {
                                        "type": "integer",
                                        "description": "规格ID（可选）"
                                    },
                                    "quantity": {
                                        "type": "integer",
                                        "description": "数量",
                                        "minimum": 1
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "成功",
                        "content": {
                            "application/json": {
