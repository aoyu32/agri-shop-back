        "/api/product/category": {
            "get": {
                "tags": [
                    "商品模块"
                ],
                "summary": "根据分类获取商品",
                "parameters": [
                    {
                        "name": "category_id",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "integer"
                        },
                        "description": "分类ID"
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 1
                        },
                        "description": "页码"
                    },
                    {
                        "name": "page_size",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 20
                        },
                        "description": "每页数量"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "成功",
