                                "example": {
                                    "code": 200,
                                    "message": "操作成功",
                                    "data": {
                                        "list": [
                                            {
                                                "id": 1,
                                                "shop_id": 1,
                                                "category_id": 202,
                                                "name": "有机西红柿",
                                                "subtitle": "新鲜有机西红柿，口感鲜美，营养丰富",
                                                "main_image": "https://...",
                                                "price": 15.80,
                                                "original_price": 20.00,
                                                "unit": "500g/份",
