                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "cart_id",
                                    "checked"
                                ],
                                "properties": {
                                    "cart_id": {
                                        "type": "integer",
                                        "description": "购物车项ID"
                                    },
                                    "checked": {
                                        "type": "integer",
                                        "description": "是否选中（0或1）",
                                        "enum": [
                                            0,
                                            1
                                        ]
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "成功",
