        "/api/product/search": {
            "get": {
                "tags": [
                    "商品模块"
                ],
                "summary": "搜索商品",
                "parameters": [
                    {
                        "name": "keyword",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        },
                        "description": "搜索关键词"
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 1
                        },
                        "description": "页码"
                    },
                    {
                        "name": "page_size",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 20
                        },
                        "description": "每页数量"
                    },
                    {
                        "name": "sort_by",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "enum": [
                                "sales",
                                "price_asc",
                                "price_desc"
                            ],
                            "default": "sales"
                        },
                        "description": "排序方式"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "成功",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Response"
                                }
                            }
                        }
                    }
                }
            }
        },
